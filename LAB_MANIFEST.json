{
  "schema_version": 1,
  "name": "Hermes Lab",
  "repo_role": "generic autoresearch lab scaffold",
  "repo_ingress_files": [
    "README.md",
    "AGENTS.md",
    "LAB_MANIFEST.json",
    "docs/AUTORESEARCH-COMPATIBILITY.md",
    "docs/REFERENCE-EXECUTOR.md",
    "docs/MULTI-FIDELITY.md",
    "docs/LOCAL-AGENT-MUTATION.md",
    "docs/DISPATCH.md",
    "docs/OPERATIONS.md"
  ],
  "data_root_env_var": "HERMES_LAB_DATA_ROOT",
  "default_data_root": "./lab-data",
  "default_data_root_requires_mount": false,
  "data_root_ingress_files": [
    "README-FIRST.md",
    "LAB-STATUS.md",
    "LAB-INDEX.json",
    "PROGRAM.md",
    "experiments/<id>/RUNBOOK.md",
    "experiments/<id>/SUMMARY.md",
    "experiments/<id>/NEXT.md",
    "experiments/<id>/SPEC.yaml"
  ],
  "commands": {
    "init": "python3 scripts/labctl.py init",
    "create_generic": "python3 scripts/labctl.py create templates/autoresearch-generic.yaml",
    "create_code_autoresearch": "python3 scripts/labctl.py create templates/code-autoresearch.yaml",
    "create_local_agent_autoresearch": "python3 scripts/labctl.py create templates/local-agent-autoresearch.yaml",
    "create_multifidelity_autoresearch": "python3 scripts/labctl.py create templates/multifidelity-autoresearch.yaml",
    "create_research_sprint": "python3 scripts/labctl.py create templates/research-sprint.yaml",
    "run_once": "python3 scripts/labctl.py run-once --max-runs 1",
    "run_once_for_class": "python3 scripts/labctl.py run-once --max-runs 1 --executor-class <executor_class>",
    "dispatch_ready": "python3 scripts/labctl.py dispatch-ready --max-runs 1",
    "dispatch_claim": "python3 scripts/labctl.py dispatch-claim --max-runs 1 --worker <worker>",
    "dispatch_work": "python3 scripts/labctl.py dispatch-work --max-runs 1 --worker <worker>",
    "dispatch_complete": "python3 scripts/labctl.py dispatch-complete <dispatch_id>",
    "dispatch_ingest": "python3 scripts/labctl.py dispatch-ingest [dispatch_id]",
    "status": "python3 scripts/labctl.py status",
    "list": "python3 scripts/labctl.py list",
    "pause": "python3 scripts/labctl.py pause <exp_id>",
    "resume": "python3 scripts/labctl.py resume <exp_id>",
    "complete": "python3 scripts/labctl.py complete <exp_id>",
    "set_fidelity": "python3 scripts/labctl.py set-fidelity <exp_id> <tier>",
    "digest": "python3 scripts/labctl.py digest",
    "weekly_digest": "python3 scripts/labctl.py weekly-digest",
    "refresh": "python3 scripts/labctl.py refresh",
    "watchdog_repair": "python3 scripts/labctl.py watchdog --repair"
  },
  "experiment_contract": {
    "canonical_files": [
      "SPEC.yaml",
      "runs/<run-id>/manifest.json",
      "runs/<run-id>/RESULT.md",
      "runs/<run-id>/metrics.json"
    ],
    "derived_files": [
      "STATUS.json",
      "RUNBOOK.md",
      "SUMMARY.md",
      "NEXT.md",
      "context.md",
      "best.md",
      "metrics.jsonl",
      "checkpoints/latest-run.txt",
      "checkpoints/best-run.txt"
    ],
    "executor_env_keys": [
      "LAB_DATA_ROOT",
      "LAB_EXPERIMENT_ID",
      "LAB_RUN_ID",
      "LAB_RUN_DIR",
      "LAB_SPEC_PATH",
      "LAB_SUMMARY_PATH",
      "LAB_NEXT_PATH",
      "LAB_CONTEXT_PATH",
      "LAB_PROGRAM_PATH",
      "LAB_ROLE",
      "LAB_LEASE_ID",
      "LAB_TIME_BUDGET_MINUTES",
      "LAB_PRIMARY_METRIC",
      "LAB_METRIC_DIRECTION",
      "LAB_FIDELITY_TIER",
      "LAB_FIDELITY_TIERS",
      "LAB_NEXT_FIDELITY_TIER",
      "LAB_EXECUTOR_CLASS",
      "LAB_WORKSPACE_ROOT",
      "LAB_SETUP_COMMAND",
      "LAB_BASELINE_COMMAND",
      "LAB_MUTATION_COMMAND",
      "LAB_AGENT_PROVIDER",
      "LAB_AGENT_MODEL",
      "LAB_AGENT_EFFORT",
      "LAB_AGENT_INSTRUCTION_FILE",
      "LAB_AGENT_BASE_URL",
      "LAB_AGENT_BACKGROUND",
      "LAB_VALIDATION_COMMAND",
      "LAB_ACCEPTANCE_RULE",
      "LAB_PROMOTION_STRATEGY",
      "LAB_WORKSPACE_MODE",
      "LAB_REQUIRE_CLEAN_WORKSPACE",
      "LAB_MUTABLE_PATHS",
      "LAB_READ_ONLY_PATHS",
      "LAB_INGRESS_FILES",
      "LAB_EGRESS_FILES",
      "LAB_ARTIFACTS_EXPECTED",
      "LAB_BEST_RUN_ID",
      "LAB_BEST_METRIC_VALUE",
      "LAB_DISPATCH_ID",
      "LAB_DISPATCH_DIR",
      "LAB_DISPATCH_STAGE"
    ]
  },
  "dispatch_contract": {
    "queue_dirs": [
      "dispatch/ready",
      "dispatch/running",
      "dispatch/complete"
    ],
    "package_files": [
      "dispatch/<dispatch-id>/dispatch.json",
      "dispatch/<dispatch-id>/README.md",
      "dispatch/<dispatch-id>/input/*",
      "dispatch/<dispatch-id>/run/manifest.json",
      "dispatch/<dispatch-id>/run/plan.md",
      "dispatch/<dispatch-id>/run/RESULT.md",
      "dispatch/<dispatch-id>/run/metrics.json"
    ],
    "stage_rule": "Packages become canonical experiment history only after dispatch-ingest copies the sealed run bundle into experiments/<id>/runs/<run-id>/."
  }
}
